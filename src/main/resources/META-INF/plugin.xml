<idea-plugin>
    <id>online.mofish.tool</id>
    <name>MoFish Tool</name>
    <vendor url="https://github.com/MrJY/mofish-tool">MrJY</vendor>
    <description><![CDATA[
        <p>MoFish Tool is a lightweight IntelliJ IDEA plugin for tracking market data without leaving the IDE.</p>
        <p>It provides watchlists, market quotes, portfolio profit calculations, configurable refresh behavior, status bar summaries, and price or percentage-change reminders.</p>
        <p>Supported quote modules include stocks, market indexes, funds, cryptocurrencies, and foreign exchange rates.</p>
        <p>mofish工具是一款 IntelliJ IDEA 行情助手插件，支持股票、指数、基金、虚拟币、外汇行情、持仓盈亏和价格提醒。</p>
    ]]></description>
    <idea-version since-build="253"/>
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
                serviceInterface="online.mofish.tool.services.MoFishAppService"
                serviceImplementation="online.mofish.tool.services.MoFishAppService"/>
        <applicationService
                serviceInterface="online.mofish.tool.services.MoFishMemoryCacheService"
                serviceImplementation="online.mofish.tool.services.MoFishMemoryCacheService"/>
        <applicationService
                serviceInterface="online.mofish.tool.services.MoFishRefreshSchedulerService"
                serviceImplementation="online.mofish.tool.services.MoFishRefreshSchedulerService"/>
        <applicationService
                serviceInterface="online.mofish.tool.settings.MoFishSettingsService"
                serviceImplementation="online.mofish.tool.settings.MoFishSettingsService"/>
        <projectService
                serviceInterface="online.mofish.tool.services.MoFishProjectService"
                serviceImplementation="online.mofish.tool.services.MoFishProjectService"/>
        <projectService
                serviceInterface="online.mofish.tool.services.MoFishReminderService"
                serviceImplementation="online.mofish.tool.services.MoFishReminderService"/>
        <projectService
                serviceInterface="online.mofish.tool.services.MoFishWatchlistService"
                serviceImplementation="online.mofish.tool.services.MoFishWatchlistService"/>

        <applicationConfigurable
                id="online.mofish.tool.settings"
                displayName="mofish工具"
                instance="online.mofish.tool.settings.MoFishSettingsConfigurable"/>
        <toolWindow
                id="mofish工具"
                anchor="left"
                canCloseContents="false"
                factoryClass="online.mofish.tool.ui.toolwindow.MoFishToolWindowFactory"
                icon="/icons/mofishToolWindow.svg"/>
        <notificationGroup
                id="MoFish Notifications"
                displayType="BALLOON"/>
        <statusBarWidgetFactory
                id="MoFishStatusBar"
                implementation="online.mofish.tool.ui.statusbar.MoFishStatusBarWidgetFactory"/>
        <fileEditorProvider
                implementation="online.mofish.tool.ui.web.MoFishWebEditorProvider"/>
    </extensions>

    <actions>
        <action
                id="online.mofish.tool.actions.OpenMoFishToolWindowAction"
                class="online.mofish.tool.actions.OpenMoFishToolWindowAction"
                text="打开mofish工具"
                description="打开mofish工具窗口"
                icon="/icons/mofishToolWindow.svg">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
